{
  "name": "pravda-market",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.1.34",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "solana:mint:devnet": "bun scripts/solana/create-devnet-usdc-mint.ts",
    "supabase:schema": "bun --env-file .env scripts/supabase/pull-schema.ts",
