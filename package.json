{
  "name": "pravda-market",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.5",
  "engines": {
    "bun": ">=1.3.5"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "collector:polymarket": "bun --env-file .env scripts/collector/polymarket-collector.ts",
    "collector:limitless": "bun --env-file .env scripts/collector/limitless-collector.ts",
    "gateway:markets-ws": "bun --env-file .env scripts/gateway/markets-ws.ts",
    "ops:reset-market-data": "bun --env-file .env scripts/supabase/reset-market-data.ts",
    "ops:reset-app-data": "bun --env-file .env scripts/supabase/reset-app-data.ts",
    "test:unit": "bun test test/unit",
    "test:unit:watch": "bun test --watch test/unit",
    "test:e2e": "playwright test",
    "test:app": "bun run test:unit && bun run test:e2e",
    "ops:check-realtime-health": "bun --env-file .env scripts/ops/check-realtime-health.ts",
    "supabase:schema": "bun --env-file .env scripts/supabase/pull-schema.ts",
    "supabase:context:cli": "bun --env-file .env scripts/supabase/pull-db-context-cli.ts",
    "supabase:context:ci": "SUPABASE_CONTEXT_REQUIRE_SQL_DUMP=true bun --env-file .env scripts/supabase/pull-db-context-cli.ts",
    "supabase:schema:check": "bun --env-file .env scripts/supabase/validate-schema.ts",
    "contracts:compile": "hardhat compile",
    "contracts:test": "hardhat test",
    "contracts:deploy:local": "hardhat run scripts/deploy/deploy-local.cjs --network localhost",
    "contracts:deploy:amoy": "hardhat run scripts/deploy/deploy-amoy.cjs --network amoy",
    "contracts:deploy:sepolia": "hardhat run scripts/deploy/deploy-sepolia.cjs --network sepolia",
    "contracts:node": "hardhat node",
    "contracts:node:kill": "bash scripts/kill-hardhat-node.sh",
    "contracts:typechain": "hardhat compile && hardhat typechain"
  },
  "dependencies": {
    "@polymarket/clob-client": "^5.3.0",
    "@privy-io/react-auth": "^3.15.0",
    "@privy-io/server-auth": "^1.32.5",
    "@supabase/ssr": "latest",
    "@supabase/supabase-js": "^2.49.0",
    "@tanstack/react-query": "^5.59.0",
    "@trpc/client": "^10.45.2",
    "@trpc/server": "^10.45.2",
    "@upstash/redis": "^1.36.3",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.3.3",
    "jose": "^5.9.3",
    "jssoup": "^0.0.15",
    "lightweight-charts": "^5.1.0",
    "lightweight-charts-react-wrapper": "^2.1.1",
    "lucide-react": "^0.555.0",
    "next": "^15.1.4",
    "openai": "^6.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.1",
    "tailwind-merge": "^2.5.3",
    "viem": "^2.46.3",
    "ws": "^8.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@playwright/test": "^1.57.0",
    "@remotion/cli": "^4.0.419",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "chai": "^4.3.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.1.4",
    "ethers": "^6.11.0",
    "hardhat": "^2.22.0",
    "postcss": "^8.4.49",
    "remotion": "^4.0.419",
    "tailwindcss": "^3.4.15",
    "typechain": "^8.3.0",
    "typescript": "~5.8.2"
  }
}
