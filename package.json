    "@types/mocha": "^10.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "chai": "^4.3.0",
    "dotenv": "^16.4.0",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.1.4",
