# ============================================================================
# Polymarket Wrapper Environment Variables
# ============================================================================

# Public app URL (for absolute links, redirects, metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ============================================================================
# Supabase (social/auth data only)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# Auth
# ============================================================================
AUTH_JWT_SECRET=replace-with-random-min-32-char-secret

# ============================================================================
# Telegram (optional, only if Telegram webhook/bot notifications are used)
# ============================================================================
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
TELEGRAM_MINIAPP_URL=

# ============================================================================
# AI context generation (optional)
# ============================================================================
OPENAI_API_KEY=
TAVILY_API_KEY=

# ============================================================================
# Polymarket API
# ============================================================================
# Optional override; defaults to https://gamma-api.polymarket.com
POLYMARKET_API_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_BASE_URL=https://clob.polymarket.com
POLYMARKET_DATA_API_BASE_URL=https://data-api.polymarket.com

# Optional URL used by "Create market" CTA in wrapper mode
NEXT_PUBLIC_POLYMARKET_CREATE_URL=https://polymarket.com
NEXT_PUBLIC_POLYMARKET_CLOB_URL=https://clob.polymarket.com
NEXT_PUBLIC_POLYMARKET_CHAIN_ID=137
POLYMARKET_RELAY_TIMEOUT_MS=10000
POLYMARKET_ACCESS_STATUS_TTL_MS=60000

# ============================================================================
# Polymarket mirror sync (server/cron)
# ============================================================================
# Used by /api/cron/polymarket-sync (Bearer token).
POLYMARKET_SYNC_SECRET=replace-with-random-secret

# ============================================================================
# Privy (auth + embedded wallets)
# ============================================================================
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
