# ============================================================================
# Polymarket Wrapper Environment Variables
# ============================================================================

# Public app URL (for absolute links, redirects, metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://localhost:3000

# ============================================================================
# Supabase (social/auth data only)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# Auth
# ============================================================================
AUTH_JWT_SECRET=replace-with-random-min-32-char-secret

# ============================================================================
# Telegram (optional, only if Telegram webhook/bot notifications are used)
# ============================================================================
TELEGRAM_BOT_TOKEN=
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
TELEGRAM_MINIAPP_URL=

# ============================================================================
# AI context generation (optional)
# ============================================================================
OPENAI_API_KEY=
TAVILY_API_KEY=

# Semantic search provider:
# - auto (default): OPENAI first, then HuggingFace, then lexical fallback
# - openai
# - huggingface
SEMANTIC_SEARCH_PROVIDER=auto
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
HUGGINGFACE_API_KEY=
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
SEMANTIC_QUERY_CACHE_TTL_MS=20000
SEMANTIC_EMBEDDING_CACHE_TTL_MS=1800000
SEMANTIC_LATEST_POOL_CACHE_TTL_MS=30000

# ============================================================================
# Polymarket API
# ============================================================================
# Optional override; defaults to https://gamma-api.polymarket.com
POLYMARKET_API_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_API_BASE_URL=https://clob.polymarket.com
POLYMARKET_DATA_API_BASE_URL=https://data-api.polymarket.com

# Optional URL used by "Create market" CTA in wrapper mode
NEXT_PUBLIC_POLYMARKET_CREATE_URL=https://polymarket.com
NEXT_PUBLIC_POLYMARKET_CLOB_URL=https://clob.polymarket.com
NEXT_PUBLIC_POLYMARKET_CHAIN_ID=137
POLYMARKET_RELAY_TIMEOUT_MS=10000
POLYMARKET_ACCESS_STATUS_TTL_MS=60000
POLYMARKET_MARKET_STALE_AFTER_MS=60000
POLYMARKET_MARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
# Backward-compatible alias if your deployment still references this name.
POLYMARKET_RTDS_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# ============================================================================
# Limitless API (multi-venue, feature-flagged)
# ============================================================================
ENABLE_LIMITLESS=false
LIMITLESS_API_BASE_URL=https://api.limitless.exchange
LIMITLESS_CHAIN_ID=8453
LIMITLESS_RTDS_WS_URL=wss://ws.limitless.exchange
LIMITLESS_ACCESS_STATUS_URL=
LIMITLESS_ORDER_RELAY_URL=
LIMITLESS_ACCESS_STATUS_TTL_MS=60000
LIMITLESS_RELAY_TIMEOUT_MS=10000

# Collector tuning (Limitless)
LIMITLESS_COLLECTOR_POLL_INTERVAL_MS=15000
LIMITLESS_COLLECTOR_FLUSH_INTERVAL_MS=2000
LIMITLESS_COLLECTOR_RECONCILE_INTERVAL_MS=900000
LIMITLESS_COLLECTOR_SNAPSHOT_LIMIT=200
LIMITLESS_COLLECTOR_HEAD_SNAPSHOT_LIMIT=80
LIMITLESS_COLLECTOR_SEED_REALTIME_FROM_SNAPSHOT=false
LIMITLESS_COLLECTOR_PRUNE_INTERVAL_MS=3600000
LIMITLESS_COLLECTOR_PRUNE_EXPIRED_AFTER_DAYS=7
LIMITLESS_COLLECTOR_ENABLE_MISSING_MARKET_PRUNE=true
LIMITLESS_COLLECTOR_MISSING_MARKET_SCAN_LIMIT=1200
LIMITLESS_COLLECTOR_MISSING_MARKET_MISS_THRESHOLD=3
LIMITLESS_COLLECTOR_PROBE_THROTTLE_MS=300000
LIMITLESS_COLLECTOR_HEALTH_PORT=8081

# ============================================================================
# Polymarket mirror sync (server/cron)
# ============================================================================
# Used by /api/cron/polymarket-sync (Bearer token).
POLYMARKET_SYNC_SECRET=replace-with-random-secret

# Collector tuning (Railway/Bun worker)
COLLECTOR_FLUSH_INTERVAL_MS=2000
COLLECTOR_NEW_MARKET_POLL_INTERVAL_MS=10000
COLLECTOR_NEW_MARKET_POLL_PAGE_SIZE=60
COLLECTOR_RECONCILE_INTERVAL_MS=900000
COLLECTOR_HEARTBEAT_TIMEOUT_MS=45000
COLLECTOR_HEARTBEAT_CLOSE_MULTIPLIER=4
COLLECTOR_WS_SUBSCRIPTION_CHUNK_SIZE=250
COLLECTOR_RECONNECT_JITTER_MS=700
COLLECTOR_DEAD_LETTER_LOG_EVERY_MS=5000
COLLECTOR_SNAPSHOT_PAGE_SIZE=150
COLLECTOR_SNAPSHOT_MAX_PAGES=3
COLLECTOR_PRUNE_INTERVAL_MS=3600000
COLLECTOR_PRUNE_EXPIRED_AFTER_DAYS=7
COLLECTOR_ENABLE_MISSING_MARKET_PRUNE=true
COLLECTOR_MISSING_MARKET_SCAN_PAGE_SIZE=200
COLLECTOR_MISSING_MARKET_SCAN_MAX_PAGES=20
COLLECTOR_MISSING_MARKET_MISS_THRESHOLD=3
COLLECTOR_MAX_TRACKED_MARKETS=500
COLLECTOR_MAX_TRACKED_ASSET_IDS=1200
COLLECTOR_ENABLE_SNAPSHOT_REALTIME_SEED=false
COLLECTOR_ENABLE_CANONICAL_REALTIME_MIRROR=false
COLLECTOR_UPSERT_CHUNK_SIZE=400
COLLECTOR_CANDLE_UPSERT_CHUNK_SIZE=400
COLLECTOR_HEALTH_PORT=8080

# Writes from market read endpoints to market_catalog are disabled by default.
ENABLE_CATALOG_SYNC_ON_READ=false

# Trust proxy forwarding headers only in known infrastructure.
TRUST_PROXY_HEADERS=true

# ============================================================================
# Privy (auth + embedded wallets)
# ============================================================================
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
